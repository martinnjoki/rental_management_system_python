# Copy to `.env` — Compose reads this file automatically for variable substitution.
SECRET_KEY=replace-with-a-long-random-secret
DB_PATH=/data/rental_system.db

# Published host port (maps HOST:5050 → container port 5050)
DOCKER_HOST_PORT=5050

# SQLite: keep at 1 unless you switch to PostgreSQL
GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=60
